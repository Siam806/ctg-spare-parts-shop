{
  "name": "ctg-spare-parts-shop",
  "private": true,
  "packageManager": "pnpm@10.16.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "start": "turbo start",
    "lint": "turbo lint",
    "test": "turbo test",
    "backend:seed": "turbo seed --filter=@ctg/backend",
    "backend:dev": "turbo dev --filter=@ctg/backend",
    "storefront:dev": "turbo dev --filter=@ctg/storefront",
    "medusa": "pnpm --filter @ctg/backend exec medusa",
    "db:migrate": "pnpm --filter @ctg/backend exec medusa db:migrate",
    "db:seed": "pnpm --filter @ctg/backend exec medusa db:seed",
    "backend:user": "pnpm --filter @ctg/backend exec medusa user"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.0.5",
      "@types/react-dom": "19.0.5"
    }
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "turbo": "^2.0.14"
  }
}