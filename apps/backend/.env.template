# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for store, admin, and auth APIs.
# Add your Vercel preview URLs and production domain here.
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:5173,http://localhost:9000
AUTH_CORS=http://localhost:5173,http://localhost:9000

# ── Secrets ─────────────────────────────────────────────────────────────────
# Generate strong random values for production:  openssl rand -hex 32
JWT_SECRET=change-me-in-production
COOKIE_SECRET=change-me-in-production

# ── Database (Neon serverless Postgres) ─────────────────────────────────────
# Obtain your connection string from https://console.neon.tech
# Format: postgresql://<user>:<password>@<host>/<dbname>?sslmode=require
DATABASE_URL=

# ── Redis ────────────────────────────────────────────────────────────────────
# Required for Medusa event bus and cache in production.
# Local:       redis://localhost:6379
# Production:  Use Upstash Redis (https://upstash.com) on Vercel.
REDIS_URL=redis://localhost:6379

# ── ERPNext sandbox ──────────────────────────────────────────────────────────
# Local Docker Compose sandbox (infrastructure/erpnext/docker-compose.yml).
# Generate an API key in ERPNext: Settings → My Account → API Access → Generate Keys
ERP_BASE_URL=http://localhost:8080
ERP_API_KEY=
ERP_API_SECRET=

# ── Shipping Carriers ───────────────────────────────────────────────────────
# SendCloud (https://panel.sendcloud.sc/integrations)
# Get API keys from: Settings → API → Generate Keys
SENDCLOUD_API_KEY=
SENDCLOUD_API_SECRET=
SENDCLOUD_SANDBOX=true

# PostNL (https://developer.postnl.nl/)
# Request API access via PostNL business account
POSTNL_API_KEY=
POSTNL_CUSTOMER_NUMBER=
POSTNL_CUSTOMER_CODE=
POSTNL_SANDBOX=true

# Sender Address (used for all carrier shipments)
SHIPPING_SENDER_NAME=CTG Spare Parts
SHIPPING_SENDER_COMPANY=CTG Parts GmbH
SHIPPING_SENDER_STREET=Industriestraße
SHIPPING_SENDER_HOUSE_NUMBER=1
SHIPPING_SENDER_CITY=Berlin
SHIPPING_SENDER_POSTAL=10115
SHIPPING_SENDER_COUNTRY=DE
SHIPPING_SENDER_PHONE=+49 30 1234567
SHIPPING_SENDER_EMAIL=shipping@ctg-parts.de
