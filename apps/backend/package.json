{
  "name": "@ctg/backend",
  "version": "0.0.1",
  "description": "Medusa v2 backend for the CTG spare parts webshop.",
  "author": "",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "medusa build",
    "start": "medusa start",
    "dev": "medusa develop",
    "test:integration:http": "cross-env TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "cross-env TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:unit": "cross-env TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit",
    "erp:ping": "tsx --env-file=.env src/modules/erp/scripts/ping.ts",
    "seed:device-lookup": "medusa exec ./src/scripts/seed-device-lookup-test-data.ts"
  },
  "dependencies": {
    "@medusajs/admin-bundler": "2.15.2",
    "@medusajs/admin-sdk": "2.15.2",
    "@medusajs/admin-shared": "2.15.2",
    "@medusajs/caching": "2.15.2",
    "@medusajs/cli": "2.15.2",
    "@medusajs/dashboard": "2.15.2",
    "@medusajs/draft-order": "2.15.2",
    "@medusajs/framework": "2.15.2",
    "@medusajs/medusa": "2.15.2",
    "@medusajs/ui": "4.1.12",
    "@tanstack/react-query": "5.64.2",
    "react-i18next": "13.5.0",
    "react-router-dom": "6.30.3",
    "zod": "4.2.0"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.15.2",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.12.11",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.14",
    "yalc": "^1.0.0-pre.53"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.16.0"
}